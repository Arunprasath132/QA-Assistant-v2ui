# Copy this file to .env for local development (never commit the real .env)
GROQ_API_KEY=your_groq_api_key_here

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-site.netlify.app

# PostgreSQL connection string (Neon/Supabase/Render/etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Long random string used to sign auth (JWT) tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_string
